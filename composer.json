{
    "name": "kaliop/content-decorator-bundle",
    "description": "Decorate your Ibexa content with custom model classes.",
    "keywords": [
        "ibexa",
        "symfony",
        "symfony-bundle",
        "content",
        "repository-pattern"
    ],
    "homepage": "https://github.com/kaliop/content-decorator-bundle",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Grzegorz Balcewicz",
            "email": "gbalcewicz@kaliop.com"
        },
        {
            "name": "Stanisław Klimaszewski",
            "email": "sklimaszewski@kaliop.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "pagerfanta/pagerfanta": "^3.6",
        "symfony/cache": "^7.0",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/http-kernel": "^7.0",
        "ibexa/core": "~5.0",
        "nyholm/psr7": "^1.8",
        "guzzlehttp/promises": "^2.5"
    },
    "require-dev": {
        "ibexa/code-style": "~2.3.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "qossmic/deptrac-shim": "^0.24.0 || ^1.0.2"
    },
    "autoload": {
        "psr-4": {
            "Kaliop\\ContentDecorator\\": "src/lib/",
            "Kaliop\\Bundle\\ContentDecorator\\": "src/bundle/",
            "Kaliop\\Contracts\\ContentDecorator\\": "src/contracts/"
        }
    },
    "scripts": {
        "fix-cs": "php-cs-fixer fix --config=.php-cs-fixer.php --show-progress=dots",
        "check-cs": "@fix-cs --dry-run",
        "phpstan": "phpstan analyse -c phpstan.neon --memory-limit=2G",
        "deptrac": "php vendor/bin/deptrac analyse"
    },
    "scripts-descriptions": {
        "fix-cs": "Automatically fixes code style in all files",
        "check-cs": "Run code style checker for all files",
        "phpstan": "Run static code analysis",
        "deptrac": "Run Deptrac architecture testing"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "support": {
        "issues": "https://github.com/kaliop/content-decorator-bundle/issues",
        "source": "https://github.com/kaliop/content-decorator-bundle",
        "docs": "https://github.com/kaliop/content-decorator-bundle#readme"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
